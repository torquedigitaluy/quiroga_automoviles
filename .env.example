# Template for server-side Supabase secrets. Copy to .env and fill in real values.
# NEVER prefix these with VITE_ (that would expose them to the browser).
# .env is gitignored; this .env.example is safe to commit (no real values).

# Project Settings → API → Project URL
SUPABASE_URL=https://<project-ref>.supabase.co

# Project Settings → API → service_role  (SECRET — bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Project Settings → Database → Connection string → URI
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Project Settings → Database → Database password  (SECRET)
SUPABASE_DB_PASSWORD=
